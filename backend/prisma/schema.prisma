generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  LOUEUR
  ADMIN
}

enum VehicleCategory {
  VOITURE
  MOTO
  BATEAU
  JETSKI
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  ACTIVE
  COMPLETED
  CANCELLED
  DISPUTED
}

enum PaymentType {
  MAIN
  CAUTION
}

enum PaymentStatus {
  PENDING
  CAPTURED
  RELEASED
  REFUNDED
}

enum TargetType {
  CLIENT
  AGENCY
}

enum ProspectStatus {
  NOT_CONTACTED
  EMAIL_SENT
  FORM_SUBMITTED
  REGISTERED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  role         Role     @default(CLIENT)
  firstName    String
  lastName     String
  phone        String?
  avatar       String?
  isVerified   Boolean  @default(false)
  isBlacklisted Boolean @default(false)
  cinPath      String?
  permisPath   String?
  googleId     String?  @unique
  resetToken        String?  @unique
  resetTokenExpiry  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  agency           Agency?
  reservations     Reservation[] @relation("ClientReservations")
  sentMessages     Message[]     @relation("SentMessages")
  receivedMessages Message[]     @relation("ReceivedMessages")
  reviewsAuthored  Review[]      @relation("AuthoredReviews")
  reviewsReceived  Review[]      @relation("ReceivedReviews")

  @@map("users")
}

model Agency {
  id               String   @id @default(cuid())
  userId           String   @unique
  name             String
  registreCommerce String
  assurancePath    String?
  description      String?
  address          String
  city             String
  lat              Float?
  lng              Float?
  rating           Float    @default(0)
  reviewCount      Int      @default(0)
  isApproved       Boolean  @default(false)
  isDemo           Boolean  @default(false)
  responseTime     Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicles     Vehicle[]
  reservations Reservation[]

  @@map("agencies")
}

model Vehicle {
  id              String          @id @default(cuid())
  agencyId        String
  category        VehicleCategory
  title           String
  description     String
  images          String[]
  pricePerDay     Float
  pricePerHour    Float?
  caution         Float
  city            String
  lat             Float?
  lng             Float?
  isAvailable     Boolean         @default(true)
  isDemo          Boolean         @default(false)
  isScraped       Boolean         @default(false)
  isApproved      Boolean         @default(true)
  sourceUrl       String?
  sourcePhone     String?
  specs           Json
  requiredLicense String
  rating          Float           @default(0)
  reviewCount     Int             @default(0)
  viewCount       Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  agency        Agency         @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  reservations  Reservation[]
  availability  Availability[]

  @@map("vehicles")
}

model Reservation {
  id            String            @id @default(cuid())
  vehicleId     String
  clientId      String
  agencyId      String
  startDate     DateTime
  endDate       DateTime
  totalPrice    Float
  commission    Float
  cautionAmount Float
  status        ReservationStatus @default(PENDING)
  pdfPath       String?
  cancelReason  String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  vehicle  Vehicle   @relation(fields: [vehicleId], references: [id])
  client   User      @relation("ClientReservations", fields: [clientId], references: [id])
  agency   Agency    @relation(fields: [agencyId], references: [id])
  payments Payment[]
  reviews  Review[]
  messages Message[]

  @@map("reservations")
}

model Payment {
  id              String        @id @default(cuid())
  reservationId   String
  amount          Float
  type            PaymentType
  status          PaymentStatus @default(PENDING)
  stripeIntentId  String?
  stripeChargeId  String?
  refundId        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  reservation Reservation @relation(fields: [reservationId], references: [id])

  @@map("payments")
}

model Review {
  id            String     @id @default(cuid())
  reservationId String
  authorId      String
  targetId      String
  targetType    TargetType
  rating        Int
  comment       String
  reply         String?
  isModerated   Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  reservation Reservation @relation(fields: [reservationId], references: [id])
  author      User        @relation("AuthoredReviews", fields: [authorId], references: [id])
  target      User        @relation("ReceivedReviews", fields: [targetId], references: [id])

  @@map("reviews")
}

model Message {
  id            String   @id @default(cuid())
  senderId      String
  receiverId    String
  reservationId String?
  content       String
  attachmentUrl String?
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())

  sender      User         @relation("SentMessages", fields: [senderId], references: [id])
  receiver    User         @relation("ReceivedMessages", fields: [receiverId], references: [id])
  reservation Reservation? @relation(fields: [reservationId], references: [id])

  @@map("messages")
}

model Availability {
  id        String   @id @default(cuid())
  vehicleId String
  date      DateTime @db.Date
  isBlocked Boolean  @default(true)
  createdAt DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([vehicleId, date])
  @@map("availability")
}

model Prospect {
  id          String         @id @default(cuid())
  name        String
  city        String
  address     String?
  phone       String?
  email       String?
  website     String?
  categories  String[]
  sourceUrl   String
  scrapedAt   DateTime       @default(now())
  status      ProspectStatus @default(NOT_CONTACTED)
  contactedAt DateTime?
  notes       String?

  @@index([city])
  @@index([status])
  @@map("prospects")
}
