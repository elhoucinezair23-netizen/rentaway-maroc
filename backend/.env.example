NODE_ENV=production
PORT=4000

# Frontend (Vercel) — sera renseigné après déploiement Vercel
FRONTEND_URL=https://your-app.vercel.app
ALLOWED_ORIGINS=https://your-app.vercel.app

# Database (Neon)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Stripe (placeholders — peuvent rester vides pour démo)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
PLATFORM_COMMISSION_RATE=0.15

# Email (placeholders)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=placeholder@example.com
SMTP_PASS=placeholder
EMAIL_FROM=noreply@rentaway.ma
ADMIN_EMAIL=admin@rentaway.ma

# Cloudinary (placeholders)
CLOUDINARY_CLOUD_NAME=placeholder
CLOUDINARY_API_KEY=placeholder
CLOUDINARY_API_SECRET=placeholder

UNSPLASH_ACCESS_KEY=
