# ─── RentaWay Maroc — Variables d'environnement ────────────────────────
# Copier vers `.env.production` (et `.env` en local) puis remplir.
# NE JAMAIS commit le fichier rempli.
# ───────────────────────────────────────────────────────────────────────

# ──────────────── Backend (Node/Express) ──────────────────────────────
NODE_ENV=production
PORT=4000

# Postgres (en Docker : host = `postgres`, sinon host:port réels)
DATABASE_URL=postgresql://rentaway_user:CHANGE_ME@postgres:5432/rentaway

# JWT — générer 32 caractères aléatoires
# $ openssl rand -base64 32
JWT_SECRET=CHANGE_ME_32_chars_random_string_here
JWT_EXPIRES_IN=7d

# CORS — URLs publiques autorisées (séparées par des virgules)
FRONTEND_URL=https://rentaway.ma
ALLOWED_ORIGINS=https://rentaway.ma,https://www.rentaway.ma

# ──────────────── Frontend (Next.js) ──────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.rentaway.ma/api
NEXTAUTH_URL=https://rentaway.ma
NEXTAUTH_SECRET=CHANGE_ME_nextauth_32_chars_random_string

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Maps API (https://console.cloud.google.com → Maps JavaScript API)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Unsplash (https://unsplash.com/developers)
UNSPLASH_ACCESS_KEY=

# ──────────────── Stripe (paiement) ───────────────────────────────────
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
NEXT_PUBLIC_STRIPE_KEY=pk_live_CHANGE_ME
PLATFORM_COMMISSION_RATE=0.15

# ──────────────── Email (SMTP) ────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=contact@rentaway.ma
SMTP_PASS=CHANGE_ME
EMAIL_FROM=noreply@rentaway.ma
ADMIN_EMAIL=admin@rentaway.ma

# ──────────────── Cloudinary (stockage photos) ────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ──────────────── Twilio (SMS, optionnel) ─────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ──────────────── Postgres (utilisé par docker-compose) ───────────────
POSTGRES_DB=rentaway
POSTGRES_USER=rentaway_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password
