# ─── RentaWay Maroc — gitignore racine ──────────────

# Environnement (secrets — JAMAIS commit)
.env
.env.local
.env.production
.env.*.local
**/.env
**/.env.local
**/.env.production
**/.env.*.local

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build
**/dist/
**/.next/
**/out/
**/build/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Prisma generated
**/node_modules/.prisma/

# Logs & exports
**/logs/
**/*.log
**/exports/*.csv
**/exports/*.json
!**/exports/.gitkeep

# Photos scrapées (volume séparé en prod)
frontend/public/uploads/scraped/

# SSL
ssl/
*.pem
*.crt
*.key

# Backups DB
*.sql
*.dump

# Docker
docker-compose.override.yml
