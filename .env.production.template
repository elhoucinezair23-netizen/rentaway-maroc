# ─── RentaWay Maroc — Production ────────────────────────────
# DOCS : voir DEPLOIEMENT.md
# ATTENTION : remplir TOUTES les valeurs avant `docker-compose up`
#
# Pour générer des secrets : openssl rand -base64 32
# ─────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=4000

# ─── Postgres ────────────────────────────────────────────────
POSTGRES_DB=rentaway
POSTGRES_USER=rentaway_user
POSTGRES_PASSWORD=REMPLIR_un_mot_de_passe_fort_32_chars

DATABASE_URL=postgresql://rentaway_user:REMPLIR_un_mot_de_passe_fort_32_chars@postgres:5432/rentaway

# ─── JWT / Auth ──────────────────────────────────────────────
JWT_SECRET=REMPLIR_32_chars_aleatoires_jwt
JWT_EXPIRES_IN=7d
NEXTAUTH_URL=https://rentaway.ma
NEXTAUTH_SECRET=REMPLIR_32_chars_aleatoires_nextauth

# ─── URLs ────────────────────────────────────────────────────
FRONTEND_URL=https://rentaway.ma
ALLOWED_ORIGINS=https://rentaway.ma,https://www.rentaway.ma
NEXT_PUBLIC_API_URL=https://api.rentaway.ma/api

# ─── OAuth Google ────────────────────────────────────────────
GOOGLE_CLIENT_ID=REMPLIR
GOOGLE_CLIENT_SECRET=REMPLIR

# ─── Google Maps ─────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_KEY=REMPLIR

# ─── Unsplash ────────────────────────────────────────────────
UNSPLASH_ACCESS_KEY=REMPLIR

# ─── Stripe (PROD KEYS) ──────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_REMPLIR
STRIPE_WEBHOOK_SECRET=whsec_REMPLIR
NEXT_PUBLIC_STRIPE_KEY=pk_live_REMPLIR
PLATFORM_COMMISSION_RATE=0.15

# ─── Email SMTP ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=contact@rentaway.ma
SMTP_PASS=REMPLIR
EMAIL_FROM=noreply@rentaway.ma
ADMIN_EMAIL=admin@rentaway.ma

# ─── Cloudinary ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=rentaway
CLOUDINARY_API_KEY=REMPLIR
CLOUDINARY_API_SECRET=REMPLIR

# ─── Twilio (optionnel) ──────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
